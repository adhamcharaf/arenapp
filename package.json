{
  "name": "arenapp",
  "version": "0.1.0",
  "private": true,
  "description": "Système de réservation sportive pour la Côte d'Ivoire avec paiement mobile money",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "db:migrate": "supabase db push",
    "db:seed": "supabase db reset --with-seed",
    "db:types": "supabase gen types typescript --local > src/types/supabase.ts"
  },
  "dependencies": {
    "@supabase/ssr": "^0.5.0",
    "@supabase/supabase-js": "^2.45.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.367.0",
    "next": "15.3.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.4.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/jest": "^29.5.5",
    "@types/node": "^20",
    "@types/react": "^18.2.41",
    "@types/react-dom": "^18.2.17",
    "eslint": "^9",
    "eslint-config-next": "15.3.5",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.6.3",
    "prettier": "^3.3.0",
    "prettier-plugin-tailwindcss": "^0.6.0",
    "supabase": "^1.188.0",
    "tailwindcss": "^4",
    "ts-jest": "^29.1.1",
    "typescript": "^5",
    "@testing-library/jest-dom": "^6.1.4"
  },
  "keywords": [
    "nextjs",
    "supabase",
    "typescript",
    "tailwindcss",
    "booking-system",
    "mobile-money",
    "ivory-coast",
    "sports-reservation"
  ],
  "author": "ARENAPP Team",
  "license": "MIT"
}
